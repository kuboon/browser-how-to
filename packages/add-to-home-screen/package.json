{
  "name": "@kuboon/how-to-a2hs",
  "version": "0.1.0",
  "description": "ホーム画面に追加できるか判定し、できなければ標準ブラウザへ誘導、できる場合は機種別の手順を案内するフロントエンド用ライブラリ",
  "type": "module",
  "files": ["dist"],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuboon/browser-how-to.git",
    "directory": "packages/add-to-home-screen"
  },
  "homepage": "https://github.com/kuboon/browser-how-to/tree/main/packages/add-to-home-screen",
  "bugs": "https://github.com/kuboon/browser-how-to/issues",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    }
  },
  "scripts": {
    "build": "vite build && node ../../scripts/jsr-self-types.mjs",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "publish:jsr": "jsr publish"
  },
  "keywords": ["add-to-home-screen", "a2hs", "pwa", "ホーム画面に追加", "in-app-browser"],
  "license": "MIT",
  "devDependencies": {
    "@kuboon/how-to-shared": "workspace:*"
  }
}
