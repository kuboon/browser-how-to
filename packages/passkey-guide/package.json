{
  "name": "@kuboon/how-to-passkeys",
  "version": "0.1.0",
  "description": "パスキー認証が使えるか判定し、使えなければ標準ブラウザへ誘導、使える場合はクロスデバイスやパスキーの仕組みをわかりやすく案内するフロントエンド用ライブラリ",
  "type": "module",
  "files": ["dist"],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuboon/browser-how-to.git",
    "directory": "packages/passkey-guide"
  },
  "homepage": "https://github.com/kuboon/browser-how-to/tree/main/packages/passkey-guide",
  "bugs": "https://github.com/kuboon/browser-how-to/issues",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    }
  },
  "scripts": {
    "build": "vite build && node ../../scripts/jsr-self-types.mjs",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "publish:jsr": "jsr publish"
  },
  "keywords": ["passkey", "webauthn", "パスキー", "cross-device", "in-app-browser"],
  "license": "MIT",
  "devDependencies": {
    "@kuboon/how-to-shared": "workspace:*"
  }
}
